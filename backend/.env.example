# Database connection configurations
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgrespassword
DB_DATABASE=gobadi

# Redis cache connection configurations
REDIS_HOST=localhost
REDIS_PORT=6379

# Cloudinary configurations for bulk image storage (optional, uses fallback if blank)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Nodemailer SMTP configurations (Optional, falls back to mock console logs if empty)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Gobadi App" <no-reply@gobadi.com>
